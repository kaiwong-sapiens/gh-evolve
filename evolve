#!/usr/bin/env python3
"""
gh-evolve: Evolutionary problem-solving over GitHub PRs.

Any agent (or human) drives the search. This CLI manages the bookkeeping:
branches, PRs, issue summary tables, and pruning.
"""

import argparse
import json
import os
import re
import subprocess
import sys
import textwrap
from pathlib import Path

BRANCH_PREFIX = "evolve"
LABEL = "evolve"


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def gh(*args, capture=True):
    """Run a gh CLI command."""
    cmd = ["gh"] + list(args)
    result = subprocess.run(cmd, capture_output=capture, text=True)
    if result.returncode != 0:
        print(f"Error: gh {' '.join(args)}", file=sys.stderr)
        print(result.stderr.strip(), file=sys.stderr)
        sys.exit(1)
    return result.stdout.strip() if capture else None


def git(*args, capture=True):
    """Run a git command."""
    cmd = ["git"] + list(args)
    result = subprocess.run(cmd, capture_output=capture, text=True)
    if result.returncode != 0:
        print(f"Error: git {' '.join(args)}", file=sys.stderr)
        print(result.stderr.strip(), file=sys.stderr)
        sys.exit(1)
    return result.stdout.strip() if capture else None


def get_issue(issue_number):
    """Fetch issue body and title."""
    raw = gh("issue", "view", str(issue_number), "--json", "title,body,state")
    return json.loads(raw)


def get_prs_for_issue(issue_number):
    """List all PRs associated with an evolution issue."""
    raw = gh(
        "pr", "list",
        "--search", f"evolve/{issue_number}/ in:head",
        "--state", "all",
        "--json", "number,title,state,headRefName,body",
        "--limit", "100",
    )
    return json.loads(raw)


def parse_score(body):
    """Extract score from PR body."""
    if not body:
        return None
    m = re.search(r"^##\s*Score:\s*(.+)$", body, re.MULTILINE)
    if m:
        try:
            return float(m.group(1).strip())
        except ValueError:
            return None
    return None


def parse_strategy(body):
    """Extract strategy from PR body."""
    if not body:
        return None
    m = re.search(r"^##\s*Strategy:\s*(.+)$", body, re.MULTILINE)
    if m:
        return m.group(1).strip()
    return None


def parse_parents(body):
    """Extract parent PR numbers from PR body."""
    if not body:
        return []
    m = re.search(r"^##\s*Parent\(s\):\s*(.+)$", body, re.MULTILINE)
    if m:
        return [int(x) for x in re.findall(r"#(\d+)", m.group(1))]
    return []


def parse_eval_command(body):
    """Extract evaluation command from issue body."""
    if not body:
        return None
    m = re.search(r"^## Evaluate\s*\n```[^\n]*\n(.+?)```", body, re.MULTILINE | re.DOTALL)
    if m:
        return m.group(1).strip()
    return None


def parse_key_insight(body):
    """Extract key insight / conclusion from PR body."""
    if not body:
        return ""
    m = re.search(r"^### Conclusion\s*\n(.+?)(?=\n##|\Z)", body, re.MULTILINE | re.DOTALL)
    if m:
        return m.group(1).strip().split("\n")[0][:80]
    return ""


def next_attempt_number(prs):
    """Determine the next attempt number."""
    nums = []
    for pr in prs:
        m = re.search(r"attempt-(\d+)", pr.get("headRefName", ""))
        if m:
            nums.append(int(m.group(1)))
    return max(nums, default=0) + 1


def build_leaderboard(prs):
    """Build a sorted leaderboard from PRs."""
    entries = []
    for pr in prs:
        score = parse_score(pr["body"])
        if score is None:
            continue
        entries.append({
            "number": pr["number"],
            "score": score,
            "strategy": parse_strategy(pr["body"]) or "?",
            "parents": parse_parents(pr["body"]),
            "state": pr["state"],
            "insight": parse_key_insight(pr["body"]),
        })
    entries.sort(key=lambda e: e["score"], reverse=True)
    return entries


def format_leaderboard(entries, top_n=None):
    """Format leaderboard as markdown table."""
    if not entries:
        return "No scored attempts yet."
    show = entries[:top_n] if top_n else entries
    lines = ["| Rank | PR | Score | Strategy | Parent(s) | Status | Key Insight |"]
    lines.append("|------|-----|-------|----------|-----------|--------|-------------|")
    for i, e in enumerate(show, 1):
        parents = ", ".join(f"#{p}" for p in e["parents"]) or "-"
        status = "open" if e["state"] == "OPEN" else "closed"
        lines.append(
            f"| {i} | #{e['number']} | {e['score']} | {e['strategy']} "
            f"| {parents} | {status} | {e['insight']} |"
        )
    return "\n".join(lines)


def update_issue_summary(issue_number, entries):
    """Replace the Summary Table section in the issue body."""
    issue = get_issue(issue_number)
    body = issue["body"] or ""

    new_table = format_leaderboard(entries)

    # Replace existing summary table or append
    pattern = r"(## Summary Table\s*\n).*?(\n## |\Z)"
    replacement = f"\\1{new_table}\n\n\\2"
    if re.search(pattern, body, re.DOTALL):
        new_body = re.sub(pattern, replacement, body, flags=re.DOTALL)
    else:
        new_body = body.rstrip() + f"\n\n## Summary Table\n{new_table}\n"

    gh("issue", "edit", str(issue_number), "--body", new_body)


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

def cmd_init(args):
    """Create a new evolution issue."""
    template_path = Path(__file__).parent / "templates" / "root_issue.md"
    if template_path.exists():
        template = template_path.read_text()
    else:
        template = textwrap.dedent("""\
            ## Objective
            {objective}

            ## Evaluate
            ```bash
            {eval_command}
            ```

            ## Constraints
            {constraints}

            ## Summary Table
            No attempts yet.

            ## Evolution Log
            - Initialized.
        """)

    body = template.format(
        objective=args.objective or "TODO: describe the objective",
        eval_command=args.eval or "TODO: add evaluation command",
        constraints=args.constraint or "None specified.",
    )

    # Ensure evolve label exists
    subprocess.run(
        ["gh", "label", "create", LABEL, "--description", "Evolution problem", "--color", "7057ff"],
        capture_output=True, text=True,
    )

    result = gh(
        "issue", "create",
        "--title", f"[Evolve] {args.title}",
        "--body", body,
        "--label", LABEL,
    )
    print(result)


def cmd_status(args):
    """Show current state of an evolution problem."""
    issue = get_issue(args.issue)
    prs = get_prs_for_issue(args.issue)
    entries = build_leaderboard(prs)

    # Parse objective and eval from issue body
    body = issue["body"] or ""
    eval_cmd = parse_eval_command(body)

    obj_match = re.search(r"## Objective\s*\n(.+?)(?=\n## )", body, re.DOTALL)
    objective = obj_match.group(1).strip() if obj_match else "?"

    constraint_match = re.search(r"## Constraints\s*\n(.+?)(?=\n## )", body, re.DOTALL)
    constraints = constraint_match.group(1).strip() if constraint_match else "None"

    print(f"# Evolution: {issue['title']} (#{args.issue})\n")
    print(f"## Objective\n{objective}\n")
    if eval_cmd:
        print(f"## Evaluate\n```bash\n{eval_cmd}\n```\n")
    print(f"## Constraints\n{constraints}\n")
    print(f"## Leaderboard ({len(entries)} scored attempts)")
    print(format_leaderboard(entries))

    if entries:
        best = entries[0]
        print(f"\n## Best Attempt (#{best['number']}) - Score: {best['score']}")
        print(f"Insight: {best['insight']}")

        # Suggest next strategy
        recent_scores = [e["score"] for e in entries[:3]]
        if len(recent_scores) >= 3 and recent_scores[0] == recent_scores[1] == recent_scores[2]:
            strategy = "explore (stagnating - try something novel)"
        elif len(entries) >= 2 and entries[0]["score"] > entries[1]["score"]:
            strategy = f"mutate (improving - refine #{best['number']})"
        else:
            strategy = "explore or crossover"
        print(f"\n## Suggested Next\nStrategy: {strategy}")

    print()


def cmd_start(args):
    """Create a branch for a new attempt."""
    prs = get_prs_for_issue(args.issue)
    attempt_num = next_attempt_number(prs)

    desc = args.description or args.strategy
    branch = f"{BRANCH_PREFIX}/{args.issue}/attempt-{attempt_num}-{desc}"
    branch = re.sub(r"[^a-zA-Z0-9/_-]", "-", branch)

    # Get default branch
    default_branch = git("rev-parse", "--abbrev-ref", "HEAD")
    remote_default = git("symbolic-ref", "refs/remotes/origin/HEAD", "--short").split("/")[-1]

    git("checkout", remote_default)
    git("pull", "--ff-only")
    git("checkout", "-b", branch)

    print(f"Branch created: {branch}")
    print(f"Attempt #{attempt_num} | Strategy: {args.strategy} | Parent(s): {args.parent or 'none'}")
    print()
    print("Make your changes, then run:")
    print(f"  evolve submit {args.issue} --score <score>")


def cmd_submit(args):
    """Open a PR with results and update the issue."""
    # Read the PR template
    template_path = Path(__file__).parent / "templates" / "attempt_pr.md"
    if template_path.exists():
        template = template_path.read_text()
    else:
        template = textwrap.dedent("""\
            ## Parent(s): {parents}
            ## Strategy: {strategy}

            ### Hypothesis
            {hypothesis}

            ### Method
            {method}

            ### Results
            {results}

            ## Score: {score}

            ### Conclusion
            {conclusion}
        """)

    parents = ", ".join(f"#{p}" for p in args.parent) if args.parent else "-"

    body = template.format(
        parents=parents,
        strategy=args.strategy or "?",
        hypothesis=args.hypothesis or "See diff.",
        method=args.method or "See diff.",
        results=args.results or "See score.",
        score=args.score,
        conclusion=args.conclusion or "TODO",
    )

    # Push branch
    branch = git("rev-parse", "--abbrev-ref", "HEAD")
    git("push", "-u", "origin", branch)

    # Create PR
    result = gh(
        "pr", "create",
        "--title", f"[Evolve] {args.title or branch}",
        "--body", body,
        "--label", LABEL,
    )
    print(result)

    # Update issue summary
    prs = get_prs_for_issue(args.issue)
    entries = build_leaderboard(prs)
    update_issue_summary(args.issue, entries)
    print(f"\nIssue #{args.issue} summary table updated.")


def cmd_show(args):
    """Show details of a specific attempt."""
    raw = gh("pr", "view", str(args.pr), "--json", "title,body,state,headRefName,additions,deletions")
    pr = json.loads(raw)

    print(f"# {pr['title']}")
    print(f"Branch: {pr['headRefName']}")
    print(f"State: {pr['state']}")
    print(f"+{pr['additions']} -{pr['deletions']} lines\n")
    if pr["body"]:
        print(pr["body"])
    print()

    # Show diff summary
    print("## Diff Summary")
    diff = gh("pr", "diff", str(args.pr), "--stat")
    print(diff)


def cmd_prune(args):
    """Close low-scoring PRs and archive them."""
    prs = get_prs_for_issue(args.issue)
    entries = build_leaderboard(prs)

    if len(entries) <= args.keep_top:
        print(f"Only {len(entries)} scored attempts. Nothing to prune.")
        return

    keep = entries[:args.keep_top]
    prune = entries[args.keep_top:]

    keep_numbers = {e["number"] for e in keep}

    print(f"Keeping top {args.keep_top}:")
    for e in keep:
        print(f"  #{e['number']} score={e['score']}")

    print(f"\nPruning {len(prune)} attempts:")
    for e in prune:
        print(f"  #{e['number']} score={e['score']}")

    if not args.yes:
        confirm = input("\nProceed? [y/N] ")
        if confirm.lower() != "y":
            print("Aborted.")
            return

    for e in prune:
        pr_data = next((p for p in prs if p["number"] == e["number"]), None)
        if pr_data and pr_data["state"] == "OPEN":
            gh("pr", "close", str(e["number"]), "--comment", "Pruned by gh-evolve (below top-{}).".format(args.keep_top))
            print(f"  Closed #{e['number']}")
            # Delete branch
            branch = pr_data.get("headRefName")
            if branch:
                subprocess.run(["git", "push", "origin", "--delete", branch], capture_output=True)

    update_issue_summary(args.issue, keep)
    print(f"\nIssue #{args.issue} summary updated.")


def cmd_eval(args):
    """Run the evaluation command from the issue."""
    issue = get_issue(args.issue)
    eval_cmd = parse_eval_command(issue["body"])
    if not eval_cmd:
        print("No evaluation command found in issue body.", file=sys.stderr)
        sys.exit(1)

    print(f"Running: {eval_cmd}\n")
    result = subprocess.run(eval_cmd, shell=True, text=True)
    sys.exit(result.returncode)


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        prog="evolve",
        description="Evolutionary problem-solving over GitHub PRs.",
    )
    sub = parser.add_subparsers(dest="command")

    # init
    p = sub.add_parser("init", help="Create a new evolution problem")
    p.add_argument("--title", required=True, help="Problem title")
    p.add_argument("--objective", help="What to optimize")
    p.add_argument("--eval", help="Evaluation command")
    p.add_argument("--constraint", help="Constraints")

    # status
    p = sub.add_parser("status", help="Show current state of a problem")
    p.add_argument("issue", type=int, help="Issue number")

    # start
    p = sub.add_parser("start", help="Create a branch for a new attempt")
    p.add_argument("issue", type=int, help="Issue number")
    p.add_argument("--strategy", choices=["mutate", "crossover", "explore"], default="explore")
    p.add_argument("--parent", type=int, nargs="+", help="Parent PR number(s)")
    p.add_argument("--description", help="Short description for branch name")

    # submit
    p = sub.add_parser("submit", help="Submit results and open a PR")
    p.add_argument("issue", type=int, help="Issue number")
    p.add_argument("--score", required=True, type=float, help="Evaluation score")
    p.add_argument("--strategy", help="Strategy used")
    p.add_argument("--parent", type=int, nargs="+", help="Parent PR number(s)")
    p.add_argument("--title", help="PR title")
    p.add_argument("--hypothesis", help="What you expected")
    p.add_argument("--method", help="What you changed")
    p.add_argument("--results", help="Raw results")
    p.add_argument("--conclusion", help="What you learned")

    # show
    p = sub.add_parser("show", help="Show details of a specific attempt")
    p.add_argument("pr", type=int, help="PR number")

    # prune
    p = sub.add_parser("prune", help="Close low-scoring attempts")
    p.add_argument("issue", type=int, help="Issue number")
    p.add_argument("--keep-top", type=int, default=5, help="How many to keep")
    p.add_argument("--yes", "-y", action="store_true", help="Skip confirmation")

    # eval
    p = sub.add_parser("eval", help="Run the evaluation command")
    p.add_argument("issue", type=int, help="Issue number")

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(1)

    commands = {
        "init": cmd_init,
        "status": cmd_status,
        "start": cmd_start,
        "submit": cmd_submit,
        "show": cmd_show,
        "prune": cmd_prune,
        "eval": cmd_eval,
    }
    commands[args.command](args)


if __name__ == "__main__":
    main()
